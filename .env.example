# llama.cpp server URL
LLAMA_URL=http://localhost:8080

# Web server port
PORT=3000

# Max context tokens (auto-detected from server, this is a fallback)
# LLAMA_MAX_CONTEXT=131072

# LLM backend: 'llama' (default) or 'claude' (switchable at runtime)
# LLM_BACKEND=llama

# Claude API (required if using claude backend)
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_MAX_TOKENS=8192

# Search engine: 'keiro' (default), 'tavily', or 'both'
# SEARCH_ENGINE=keiro

# Keiro search API key (get one at https://keirolabs.cloud)
# KEIRO_API_KEY=keiro-your-key-here

# Tavily search API key (optional, get one at https://tavily.com)
# TAVILY_API_KEY=tvly-your-key-here

# E*TRADE API (get keys at https://developer.etrade.com)
# ETRADE_CONSUMER_KEY=your-consumer-key
# ETRADE_CONSUMER_SECRET=your-consumer-secret
# ETRADE_SANDBOX=true

# LiteAPI hotel/travel API (get keys at https://www.liteapi.travel)
# LITEAPI_KEY=sand_your-key-here

# Python virtual environment path for run_python tool (optional)
# PYTHON_VENV=~/uv_python_env

# Keiro API base URL (optional, default: https://kierolabs.space/api)
# KEIRO_BASE_URL=https://kierolabs.space/api

# User location for weather/travel queries and {$location} macro (optional)
# LOCATION=New York, NY

# Project root path for source tools — self-awareness + code editing (optional)
# SOURCE_DIR=/path/to/this/project

# Test command for source_test tool — runs in SOURCE_DIR (optional)
# The LLM calls this after making code changes to verify they work.
# Set to whatever test/check command your project uses:
#   Node.js:  SOURCE_TEST=npm test
#   Python:   SOURCE_TEST=pytest -x
#   Go:       SOURCE_TEST=go test ./...
#   Rust:     SOURCE_TEST=cargo test
#   Java:     SOURCE_TEST=mvn test
#   C/C++:    SOURCE_TEST=make test
#   Ruby:     SOURCE_TEST=bundle exec rspec
#   PHP:      SOURCE_TEST=./vendor/bin/phpunit
#   .NET:     SOURCE_TEST=dotnet test
#   Elixir:   SOURCE_TEST=mix test
#   Syntax only (Node): SOURCE_TEST=node --check src/**/*.js
# SOURCE_TEST=npm test
