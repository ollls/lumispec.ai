{
  "name": "llm-workbench",
  "version": "0.1.0",
  "description": "LLM Workbench - prompt interface with memory management and RAG",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "css:build": "npx @tailwindcss/cli -i src/public/css/input.css -o src/public/css/output.css",
    "css:watch": "npx @tailwindcss/cli -i src/public/css/input.css -o src/public/css/output.css --watch",
    "build": "npm run css:build"
  },
  "keywords": [
    "llm",
    "ai",
    "rag"
  ],
  "license": "ISC",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/cli": "^4.2.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "got-scraping": "^4.2.1",
    "linkedom": "^0.18.12",
    "oauth": "^0.10.2",
    "puppeteer-core": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "turndown": "^7.2.2",
    "ws": "^8.20.0"
  }
}
