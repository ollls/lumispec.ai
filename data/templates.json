    "id": "6df0cfb4-3664-4f19-a6b0-5cf1d9f249b0",
    "name": "Weather",
    "type": "html",
    "html": "<!DOCTYPE html>\n<html><head>\n<style>\n* { box-sizing: border-box; }\nbody { \n  margin: 0; padding: 24px; \n  background: #1a1a2e; \n  font-family: system-ui, -apple-system, sans-serif;\n  color: #e0e0e0;\n  min-height: 100vh;\n}\n.container { max-width: 1200px; margin: 0 auto; }\nh1 { color: #4a9eff; margin-bottom: 8px; font-size: 32px; }\n.subtitle { color: #7c3aed; margin-bottom: 32px; }\n.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-top: 24px; }\n.card { \n  background: #16213e; \n  border: 1px solid #2a2a4a; \n  border-radius: 12px; \n  padding: 24px;\n}\n.card-header { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }\n.time-display { font-size: 48px; font-weight: 700; color: #4a9eff; line-height: 1; }\n.date-display { font-size: 18px; color: #e0e0e0; margin-top: 8px; }\n.current-temp { font-size: 56px; font-weight: 700; color: #f59e0b; }\n.temp-label { color: #7c3aed; font-size: 14px; margin-top: 4px; }\n.weather-icon { font-size: 48px; }\n.forecast-item { \n  display: flex; \n  align-items: center; \n  justify-content: space-between; \n  padding: 12px 0;\n  border-bottom: 1px solid #2a2a4a;\n}\n.forecast-item:last-child { border-bottom: none; }\n.forecast-day { font-weight: 600; color: #e0e0e0; width: 80px; }\n.forecast-summary { flex: 1; color: #b0b0c0; margin-left: 12px; }\n.forecast-temp { color: #f59e0b; font-weight: 600; min-width: 80px; text-align: right; }\n.forecast-humidity { font-size: 12px; color: #7c3aed; margin-left: 8px; }\n.stat-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }\n.stat-item { background: #1a1a2e; padding: 16px; border-radius: 8px; }\n.stat-label { font-size: 12px; color: #7c3aed; margin-bottom: 4px; }\n.stat-value { font-size: 24px; font-weight: 700; color: #e0e0e0; }\n.stats-section h3 { margin-bottom: 16px; color: #4a9eff; }\n@media (max-width: 600px) {\n  .current-temp { font-size: 42px; }\n  .time-display { font-size: 36px; }\n}\n</style>\n</head><body>\n<div class=\"container\">\n<h1>🌤️ {$location}</h1>\n<div class=\"subtitle\">Real-time weather and time updates</div>\n\n<div class=\"grid\">\n  <div class=\"card\">\n    <div class=\"card-header\">\n      <div class=\"time-display\" id=\"currentTime\">00:33:32</div>\n    </div>\n    <div class=\"date-display\" id=\"currentDate\">Saturday, March 21, 2026</div>\n    <div style=\"margin-top: 16px; font-size: 14px; color: #7c3aed;\">Eastern Daylight Time (UTC-4)</div>\n  </div>\n\n  <div class=\"card\">\n    <div class=\"card-header\">\n      <div class=\"weather-icon\">☀️</div>\n    </div>\n    <div class=\"current-temp\">26°C</div>\n    <div class=\"temp-label\">High: 27°C / Low: 20°C</div>\n    <div style=\"margin-top: 16px; font-size: 14px; color: #7c3aed;\">Partly cloudy with clear spells</div>\n  </div>\n</div>\n\n<div class=\"grid\" style=\"margin-top: 24px;\">\n  <div class=\"card stats-section\">\n    <h3>📅 7-Day Forecast</h3>\n    <div id=\"forecastList\"></div>\n  </div>\n\n  <div class=\"card stats-section\">\n    <h3>📊 Weather Statistics</h3>\n    <div class=\"stat-grid\">\n      <div class=\"stat-item\">\n        <div class=\"stat-label\">Average High</div>\n        <div class=\"stat-value\" id=\"avgHigh\">26.5°C</div>\n      </div>\n      <div class=\"stat-item\">\n        <div class=\"stat-label\">Average Low</div>\n        <div class=\"stat-value\" id=\"avgLow\">21.9°C</div>\n      </div>\n      <div class=\"stat-item\">\n        <div class=\"stat-label\">Avg Humidity</div>\n        <div class=\"stat-value\" id=\"avgHumidity\">46%</div>\n      </div>\n      <div class=\"stat-item\">\n        <div class=\"stat-label\">Avg Wind Speed</div>\n        <div class=\"stat-value\" id=\"avgWind\">6.4 m/s</div>\n      </div>\n    </div>\n  </div>\n</div>\n</div>\n\n<script>\nconst WEATHER = [\n  { date: \"2026-03-21\", summary: \"Today - partly cloudy with clear spells\", tempHigh: 26.2, tempLow: 19.9, humidity: 39, windSpeed: 6.48, rain: \"clear sky\", clouds: 0 },\n  { date: \"2026-03-22\", summary: \"Partly cloudy with clear spells\", tempHigh: 26.2, tempLow: 19.9, humidity: 39, windSpeed: 6.48, rain: \"clear sky\", clouds: 0 },\n  { date: \"2026-03-23\", summary: \"Clear sky today\", tempHigh: 27.1, tempLow: 20.0, humidity: 29, windSpeed: 5.03, rain: \"clear sky\", clouds: 0 },\n  { date: \"2026-03-24\", summary: \"Clear sky today\", tempHigh: 26.6, tempLow: 19.6, humidity: 40, windSpeed: 5.65, rain: \"clear sky\", clouds: 0 },\n  { date: \"2026-03-25\", summary: \"Light rain in late morning\", tempHigh: 25.4, tempLow: 23.3, humidity: 57, windSpeed: 4.3, rain: \"light rain\", clouds: 32 },\n  { date: \"2026-03-26\", summary: \"Rain in morning, clearing afternoon\", tempHigh: 26.5, tempLow: 22.8, humidity: 58, windSpeed: 6.27, rain: \"light rain\", clouds: 12 },\n  { date: \"2026-03-27\", summary: \"Partly cloudy with rain\", tempHigh: 26.6, tempLow: 23.3, humidity: 60, windSpeed: 7.23, rain: \"light rain\", clouds: 15 },\n  { date: \"2026-03-28\", summary: \"Rain in afternoon\", tempHigh: 26.4, tempLow: 23.7, humidity: 61, windSpeed: 9.42, rain: \"light rain\", clouds: 93 }\n];\n\nconst TIME = { date: \"Sat Mar 21 2026 00:33:32 GMT-0400\" };\n\ndocument.getElementById('currentTime').textContent = TIME.date.split(' ').slice(4,5).join(' ');\ndocument.getElementById('currentDate').textContent = TIME.date.split(' ').slice(0,4).join(' ');\n\nconst today = new Date(TIME.date);\nconst timeStr = today.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true });\ndocument.getElementById('currentTime').textContent = timeStr;\n\nlet html = '';\nWEATHER.forEach((d, i) => {\n  const dateObj = new Date(d.date);\n  const dayName = d.date === new Date(TIME.utc).toISOString().split(\"T\")[0] ? 'Today' : dateObj.toLocaleDateString('en-US', { weekday: 'short' });\n  const icon = d.rain.includes('rain') ? '🌧️' : d.clouds > 50 ? '☁️' : '☀️';\n  html += `<div class=\"forecast-item\">\n    <div class=\"forecast-day\">${dayName}</div>\n    <div class=\"forecast-summary\">${icon} ${d.summary.split(',')[0]}</div>\n    <div class=\"forecast-temp\">H: ${Math.round(d.tempHigh)}° L: ${Math.round(d.tempLow)}°</div>\n  </div>`;\n});\ndocument.getElementById('forecastList').innerHTML = html;\n\nconst avgHigh = WEATHER.reduce((s,d)=>s+d.tempHigh,0)/WEATHER.length;\nconst avgLow = WEATHER.reduce((s,d)=>s+d.tempLow,0)/WEATHER.length;\nconst avgHum = WEATHER.reduce((s,d)=>s+d.humidity,0)/WEATHER.length;\nconst avgWind = WEATHER.reduce((s,d)=>s+d.windSpeed,0)/WEATHER.length;\n\ndocument.getElementById('avgHigh').textContent = avgHigh.toFixed(1) + '°C';\ndocument.getElementById('avgLow').textContent = avgLow.toFixed(1) + '°C';\ndocument.getElementById('avgHumidity').textContent = Math.round(avgHum) + '%';\ndocument.getElementById('avgWind').textContent = avgWind.toFixed(1) + ' m/s';\n</script>\n</body></html>",
    "createdAt": "2026-03-21T04:34:07.456Z"
  },
