    "name": "Option Chain",
    "type": "html",
    "html": "<!DOCTYPE html>\n<html><head>\n<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>AMD Option Chain Dashboard</title>\n<style>\n*{box-sizing:border-box;margin:0;padding:0}\nbody{font-family:system-ui,-apple-system,sans-serif;background:#1a1a2e;color:#e0e0e0;padding:24px;line-height:1.5}\n.container{max-width:1400px;margin:0 auto}\n.header{text-align:center;margin-bottom:28px;padding:28px;background:#16213e;border-radius:16px;border:1px solid #2a2a4a}\nh1{font-size:36px;color:#4a9eff;margin-bottom:8px;font-weight:700}\n.subtitle{color:#7c3aed;font-size:16px}\n.controls{display:flex;gap:20px;margin-bottom:28px;padding:28px;background:#16213e;border-radius:16px;border:1px solid #2a2a4a;flex-wrap:wrap}\n.control-group{display:flex;flex-direction:column;gap:10px;min-width:220px}\n.label{font-weight:700;color:#4a9eff;font-size:15px;text-transform:uppercase;letter-spacing:0.5px}\nselect,input{padding:14px 18px;font-size:16px;background:#2a2a4a;border:2px solid #4a9eff;border-radius:10px;color:#e0e0e0;min-width:220px;cursor:pointer;font-weight:500}\nselect:hover,input:hover{border-color:#7c3aed}\nbutton{padding:14px 28px;font-size:17px;font-weight:700;background:#4a9eff;border:none;border-radius:10px;color:#1a1a2e;cursor:pointer;transition:all 0.2s;font-weight:600}\nbutton:hover{background:#7c3aed}\n.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;margin-bottom:28px}\n.stat-card{padding:24px;background:#16213e;border-radius:16px;border:1px solid #2a2a4a;text-align:center}\n.stat-value{font-size:32px;font-weight:700;color:#4a9eff;margin-bottom:6px}\n.stat-label{color:#7c3aed;font-size:14px;text-transform:uppercase;letter-spacing:0.5px}\n.table-container{overflow-x:auto;background:#16213e;border-radius:16px;border:1px solid #2a2a4a;padding:4px}\ntable{width:100%;border-collapse:collapse}\nth,td{padding:16px 14px;text-align:right;font-size:14px}\nth{text-align:center;background:#2a2a4a;color:#4a9eff;font-weight:700;text-transform:uppercase;font-size:13px;position:sticky;top:0;z-index:10}\ntd{border-bottom:1px solid #2a2a4a;color:#e0e0e0;white-space:nowrap}\ntr:hover{background:#2a2a4a}\ntr:nth-child(even){background:#1a1a2e}\n.center{text-align:center}\n.moneyness-ITM{color:#10b981;font-weight:700}\n.moneyness-OTM{color:#ef4444}\n.loading{text-align:center;padding:60px;color:#7c3aed;font-size:20px}\n.error{text-align:center;padding:40px;color:#ef4444;font-size:18px;background:#1a1a2e;border-radius:10px;margin:16px 0}\n.no-data{text-align:center;padding:40px;color:#7c3aed;font-size:18px;background:#1a1a2e;border-radius:10px;margin:16px 0}\n.badge{display:inline-block;padding:5px 12px;border-radius:5px;font-size:12px;font-weight:700;text-transform:uppercase}\n.badge-call{background:#4a9eff;color:#1a1a2e}\n.badge-put{background:#ef4444;color:#1a1a2e}\n@media(max-width:768px){body{padding:16px}.controls{flex-direction:column}.control-group{min-width:100%}}\n</style>\n</head><body>\n<div class=\"container\">\n<div class=\"header\"><h1>AMD Option Chain Dashboard</h1><div class=\"subtitle\">Real-time Greeks & Market Data from E*TRADE</div></div>\n<div class=\"controls\">\n<div class=\"control-group\">\n<label class=\"label\">Select Expiry Date</label>\n<select id=\"expirySelect\"></select>\n</div>\n<div class=\"control-group\">\n<label class=\"label\">Option Type</label>\n<select id=\"typeSelect\"><option value=\"CALL\" selected>CALL</option><option value=\"PUT\">PUT</option></select>\n</div>\n<div class=\"control-group\"><button onclick=\"loadChain()\">Load Option Chain</button></div>\n</div>\n<div class=\"stats\" id=\"stats\"></div>\n<div class=\"table-container\" id=\"tableContainer\">\n<div class=\"loading\">Loading option chain data...</div>\n</div>\n</div>\n<script>\nconst FILES = [\"optionchains_1774531833462.csv\"];\nasync function loadCSV(url){if(!url.startsWith(\"/\"))url=\"/files/\"+url;const res=await fetch(url);const text=await res.text();const rows=text.trim().split(\"\\n\");const headers=rows[0].split(\",\").map(h=>h.trim());return rows.slice(1).map(r=>{const v=r.split(\",\");return Object.fromEntries(headers.map((h,i)=>[h,v[i]?.trim()||\"\"]));});}\nfunction formatNum(n){if(n===null||n===undefined||n===\"\")return\"-\";return Number(n)>=100?Number(n).toLocaleString(\"en-US\",{minimumFractionDigits:2,maximumFractionDigits:2}):Number(n).toFixed(4)}\nfunction formatPct(n){const v=Number(n);return isNaN(v)?\"-\":v*100>99?v.toFixed(0)+\"%\":v.toFixed(1)+\"%\"}\nfunction formatVolume(n){return Number(n)>1e6?(Number(n)/1e6).toFixed(2)+\"M\":Number(n)>1e3?(Number(n)/1e3).toFixed(1)+\"K\":String(n)}\nasync function loadChain(){try{const sel=document.getElementById(\"expirySelect\");const expiry=sel.options[sel.selectedIndex]?.text||sel.value;const type=document.getElementById(\"typeSelect\").value;document.getElementById(\"tableContainer\").innerHTML=\"<div class='loading'>Loading option chain data for \" + expiry + \"...</div>\"let csv=await loadCSV(\"/files/\"+document.getElementById(\"expirySelect\").value);csv=csv.filter(r=>String(r.Type).toUpperCase()===type.toUpperCase());if(csv.length===0){document.getElementById(\"tableContainer\").innerHTML=\"<div class='no-data'>No \" + type + \" options found for this expiry</div>\"return;}const itmCount=csv.filter(r=>r[\"In The Money\"]===\"y\").length;const totalOI=csv.reduce((s,r)=>s+(Number(r[\"Open Interest\"])||0),0);const totalVol=csv.reduce((s,r)=>s+(Number(r.Volume)||0),0);document.getElementById(\"stats\").innerHTML=\"<div class='stat-card'><div class='stat-value'>\" + csv.length + \"</div><div class='stat-label'>Contracts</div></div><div class='stat-card'><div class='stat-value'>\" + itmCount + \" (\" + ((itmCount/csv.length*100)||0).toFixed(1) + \"%)</div><div class='stat-label'>In-The-Money</div></div><div class='stat-card'><div class='stat-value'>\" + formatVolume(totalOI) + \"</div><div class='stat-label'>Open Interest</div></div><div class='stat-card'><div class='stat-value'>\" + formatVolume(totalVol) + \"</div><div class='stat-label'>Volume</div></div>\"let html=\"<table><thead><tr><th class='center'>Strike</th><th class='center'>Bid</th><th class='center'>Ask</th><th class='center'>Last</th><th class='center'>Vol</th><th class='center'>OI</th><th class='center'>IV</th><th class='center'>Δ</th><th class='center'>Γ</th><th class='center'>Θ</th><th class='center'>V</th><th class='center'>Status</th></tr></thead><tbody>\";const strikes=[...new Set(csv.map(r=>r.Strike))].sort((a,b)=>Number(a)-Number(b));for(const s of strikes){const opt=csv.find(r=>r.Strike===s);if(!opt)continue;const isITM=opt[\"In The Money\"]===\"y\";html+=\"<tr><td class='center'><b>\" + (s||\"-\") + \"</b></td><td>\" + formatNum(opt.Bid) + \"</td><td>\" + formatNum(opt.Ask) + \"</td><td>\" + formatNum(opt.Last) + \"</td><td class='center'>\" + formatVolume(opt.Volume) + \"</td><td class='center'>\" + formatVolume(opt[\"Open Interest\"]) + \"</td><td class='center'>\" + formatPct(opt.IV) + \"</td><td class='center'>\" + formatPct(opt.Delta) + \"</td><td class='center'>\" + formatNum(opt.Gamma) + \"</td><td class='center'>\" + formatNum(opt.Theta) + \"</td><td class='center'>\" + formatNum(opt.Vega) + \"</td><td class='center'><span class='badge badge-\" + type.toLowerCase() + \"'>\" + (isITM?\"ITM\":\"OTM\") + \"</span></td></tr>\";}html+=\"</tbody></table>\";document.getElementById(\"tableContainer\").innerHTML=html}catch(e){console.error(e);document.getElementById(\"tableContainer\").innerHTML=\"<div class='error'>Error loading data: \" + e.message + \"</div>\"}}\nwindow.onload=async function(){const select=document.getElementById(\"expirySelect\");for(const f of FILES){const rows=await loadCSV(f);const expiry=rows[0]?.Expiry||f;const opt=document.createElement(\"option\");opt.value=f;opt.textContent=expiry;select.appendChild(opt);}select.value=FILES[0];loadChain();};\n</script>\n</body></html>",
    "createdAt": "2026-03-20T22:34:18.514Z"
  }
]