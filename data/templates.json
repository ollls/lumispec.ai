[
  {
    "id": "6259b310-d496-490e-bff6-db51846bbe6a",
    "name": "Portfolio Dashboard",
    "type": "html",
    "html": "<!DOCTYPE html>\n<html><head>\n<style>\n* { box-sizing: border-box; }\nbody { margin: 0; padding: 20px; background: #1a1a2e; color: #e0e0e0; font-family: system-ui, -apple-system, sans-serif; }\n.container { max-width: 1400px; margin: 0 auto; }\nh1 { color: #4a9eff; margin-bottom: 24px; font-size: 28px; }\nh2 { color: #4a9eff; margin-bottom: 16px; font-size: 20px; }\n.cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px; margin-bottom: 30px; }\n.card { background: #16213e; border-radius: 12px; padding: 20px; border: 1px solid #2a2a4a; }\n.card h2 { color: #7c3aed; margin: 0 0 16px 0; font-size: 18px; border-bottom: 1px solid #2a2a4a; padding-bottom: 12px; }\n.row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #2a2a4a; }\n.row:last-child { border-bottom: none; }\n.label { color: #a0a0a0; }\n.value { font-weight: 600; }\n.tbl { width: 100%; border-collapse: collapse; font-size: 13px; }\n.tbl th { text-align: left; padding: 8px; background: #1a1a2e; color: #4a9eff; font-weight: 600; }\n.tbl td { padding: 8px; border-bottom: 1px solid #2a2a4a; }\n.tbl tr:hover { background: #2a2a4a; }\n.tbl td:nth-child(n+3), .tbl th:nth-child(n+3) { text-align: right; }\n.tbl tr:nth-child(even) { background: #1a1a2e; }\n.tbl tfoot td { font-weight: 700; border-top: 2px solid #4a9eff; background: #16213e; }\n.g { color: #10b981; } .r { color: #ef4444; }\n.badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }\n.b-eq { background: #4a9eff; color: white; } .b-op { background: #7c3aed; color: white; }\n.loading { text-align: center; padding: 40px; color: #7c3aed; font-size: 18px; }\n.error { text-align: center; padding: 40px; color: #ef4444; font-size: 16px; }\n.combined { border-color: #4a9eff; margin-bottom: 24px; }\n.combined h2 { color: #4a9eff; }\n</style>\n</head><body>\n<div class=\"container\" id=\"root\"><div class=\"loading\">Loading portfolio data...</div></div>\n<script>\nconst FILES = [\"portfolio.json\"];\nconst D = (n) => typeof n===\"number\" ? n.toLocaleString(\"en-US\",{style:\"currency\",currency:\"USD\"}) : \"\\u2014\";\nconst P = (n) => typeof n===\"number\" ? (n>=0?\"+\":\"\") + n.toFixed(2)+\"%\" : \"\\u2014\";\nconst C = (n) => n>=0?\"g\":\"r\";\n\nfunction parseEtrade(raw) {\n  const tot = raw.Totals || {};\n  const positions = (raw.AccountPortfolio?.[0]?.Position || []).map(p => {\n    const pr = p.Product || {};\n    const isOpt = pr.securityType === \"OPTN\";\n    return {\n      symbol: pr.symbol || p.symbolDescription,\n      desc: p.symbolDescription,\n      type: isOpt ? pr.callPut : \"EQ\",\n      strike: isOpt ? pr.strikePrice : null,\n      expiry: isOpt ? pr.expiryYear+\"-\"+String(pr.expiryMonth).padStart(2,\"0\")+\"-\"+String(pr.expiryDay).padStart(2,\"0\") : null,\n      qty: p.quantity, cost: p.totalCost, market: p.marketValue,\n      gain: p.totalGain, gainPct: p.totalGainPct,\n      dayGain: p.daysGain, dayGainPct: p.daysGainPct\n    };\n  });\n  return {\n    account: { totalValue: tot.totalMarketValue||0, totalCost: tot.totalPricePaid||0,\n      cashBalance: tot.cashBalance||0, dayGain: tot.todaysGainLoss||0, dayGainPct: tot.todaysGainLossPct||0 },\n    positions\n  };\n}\n\nfunction badge(p) {\n  if (p.type===\"EQ\") return '<span class=\"badge b-eq\">EQ</span>';\n  return '<span class=\"badge b-op\">'+p.type+(p.strike ? \" $\"+p.strike : \"\")+'</span>';\n}\n\nfunction renderCard(name, a) {\n  return '<div class=\"card\"><h2>'+name+'</h2>'+\n    '<div class=\"row\"><span class=\"label\">Total Value</span><span class=\"value\">'+D(a.totalValue)+'</span></div>'+\n    '<div class=\"row\"><span class=\"label\">Total Cost</span><span class=\"value\">'+D(a.totalCost)+'</span></div>'+\n    '<div class=\"row\"><span class=\"label\">Cash Balance</span><span class=\"value\">'+D(a.cashBalance)+'</span></div>'+\n    (typeof a.dayGain===\"number\"?'<div class=\"row\"><span class=\"label\">Day Gain/Loss</span><span class=\"value '+C(a.dayGain)+'\">'+D(a.dayGain)+' ('+P(a.dayGainPct)+')</span></div>':\"\")+\n    '</div>';\n}\n\nfunction renderTable(title, positions) {\n  if (!positions || !positions.length) return \"\";\n  var tC=0,tM=0,tG=0,tD=0;\n  var rows = positions.map(function(p) {\n    tC+=p.cost||0; tM+=p.market||0; tG+=p.gain||0; tD+=p.dayGain||0;\n    return \"<tr><td>\"+p.symbol+\"</td><td>\"+badge(p)+\"</td><td>\"+p.qty+\"</td>\"+\n      \"<td>\"+D(p.cost)+\"</td><td>\"+D(p.market)+\"</td>\"+\n      '<td class=\"'+C(p.gain)+'\">'+D(p.gain)+\"</td>\"+\n      '<td class=\"'+C(p.gainPct)+'\">'+P(p.gainPct)+\"</td>\"+\n      '<td class=\"'+C(p.dayGain)+'\">'+D(p.dayGain)+\"</td></tr>\";\n  }).join(\"\");\n  var tP = tC ? ((tG/Math.abs(tC))*100) : 0;\n  return \"<h2>\"+title+\" (\"+positions.length+\")</h2>\"+\n    '<div style=\"overflow-x:auto;margin-bottom:20px\"><table class=\"tbl\">'+\n    \"<thead><tr><th>Symbol</th><th>Type</th><th>Qty</th><th>Cost</th><th>Market</th><th>Gain/Loss</th><th>%</th><th>Day</th></tr></thead>\"+\n    \"<tbody>\"+rows+\"</tbody>\"+\n    '<tfoot><tr><td colspan=\"3\"><strong>Total</strong></td>'+\n    \"<td>\"+D(tC)+\"</td><td>\"+D(tM)+\"</td>\"+\n    '<td class=\"'+C(tG)+'\">'+D(tG)+\"</td>\"+\n    '<td class=\"'+C(tP)+'\">'+P(tP)+\"</td>\"+\n    '<td class=\"'+C(tD)+'\">'+D(tD)+\"</td></tr></tfoot>\"+\n    \"</table></div>\";\n}\n\nasync function load() {\n  try {\n    var root = document.getElementById(\"root\");\n    var html = \"<h1>Portfolio Dashboard</h1>\";\n    var cards = [], tables = [];\n    var gC=0, gM=0, gG=0, gD=0;\n\n    for (var i=0; i<FILES.length; i++) {\n      var file = FILES[i];\n      var res = await fetch(\"/files/\"+file);\n      if (!res.ok) { html += '<div class=\"error\">Failed to load '+file+' ('+res.status+')</div>'; continue; }\n      var raw = await res.json();\n\n      if (raw.AccountPortfolio) {\n        var name = file.replace(\"portfolio_\",\"\").replace(\".json\",\"\");\n        var parsed = parseEtrade(raw);\n        cards.push(renderCard(name, parsed.account));\n        if (parsed.positions.length) tables.push(renderTable(name, parsed.positions));\n        gC+=parsed.account.totalCost; gM+=parsed.account.totalValue;\n        gG+=(parsed.account.totalValue-parsed.account.totalCost); gD+=parsed.account.dayGain;\n      } else if (raw.accounts) {\n        raw.accounts.forEach(function(a) { cards.push(renderCard(a.name||\"Account\", a)); });\n        if (raw.positions) Object.entries(raw.positions).forEach(function(e) { if(e[1].length) tables.push(renderTable(e[0],e[1])); });\n      }\n    }\n\n    if (cards.length) html += '<div class=\"cards\">'+cards.join(\"\")+'</div>';\n    if (cards.length > 1) {\n      var gP = gC ? ((gG/Math.abs(gC))*100) : 0;\n      html += '<div class=\"card combined\"><h2>Combined Totals</h2>'+\n        '<div class=\"row\"><span class=\"label\">Total Cost</span><span class=\"value\">'+D(gC)+'</span></div>'+\n        '<div class=\"row\"><span class=\"label\">Market Value</span><span class=\"value\">'+D(gM)+'</span></div>'+\n        '<div class=\"row\"><span class=\"label\">Total Gain/Loss</span><span class=\"value '+C(gG)+'\">'+D(gG)+' ('+P(gP)+')</span></div>'+\n        '<div class=\"row\"><span class=\"label\">Day Gain/Loss</span><span class=\"value '+C(gD)+'\">'+D(gD)+'</span></div></div>';\n    }\n    html += tables.join(\"\");\n    root.innerHTML = html;\n  } catch(e) {\n    document.getElementById(\"root\").innerHTML = '<div class=\"error\">Error: '+e.message+'</div>';\n  }\n}\nload();\n</script>\n</body></html>",
    "createdAt": "2026-03-26T16:27:16.553Z"
  },
  {
    "id": "d2400070-06e1-4c4e-bb98-803b73a5edb8",
    "name": "Beautiful Watch",
    "type": "html",
    "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Analog Watch</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body {\n    background: #1a1a2e;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    min-height: 100vh;\n    font-family: system-ui, -apple-system, sans-serif;\n  }\n  .watch-container {\n    background: #0f0f1a;\n    border: 8px solid #2a2a4a;\n    border-radius: 50%;\n    padding: 40px;\n    position: relative;\n    box-shadow: 0 0 60px rgba(74, 158, 255, 0.15), inset 0 0 40px rgba(0,0,0,0.5);\n  }\n  .watch-face {\n    width: 320px;\n    height: 320px;\n    background: radial-gradient(circle at 30% 30%, #1e1e3a, #0a0a15);\n    border-radius: 50%;\n    position: relative;\n    box-shadow: inset 0 0 20px rgba(0,0,0,0.6);\n  }\n  .mark {\n    position: absolute;\n    width: 4px;\n    height: 20px;\n    background: #4a9eff;\n    left: 50%;\n    top: 10px;\n    transform-origin: 50% 150px;\n    border-radius: 2px;\n  }\n  .mark.hour {\n    width: 6px;\n    height: 30px;\n    background: #7c3aed;\n  }\n  .mark.hour:nth-child(1), .mark.hour:nth-child(4), .mark.hour:nth-child(7), .mark.hour:nth-child(10) {\n    width: 8px;\n    height: 38px;\n    background: #10b981;\n  }\n  .center-dot {\n    position: absolute;\n    width: 12px;\n    height: 12px;\n    background: #ef4444;\n    border-radius: 50%;\n    left: 50%;\n    top: 50%;\n    transform: translate(-50%, -50%);\n    z-index: 10;\n    box-shadow: 0 0 8px rgba(239, 68, 68, 0.6);\n  }\n  .hand {\n    position: absolute;\n    left: 50%;\n    bottom: 50%;\n    transform-origin: 50% 100%;\n    border-radius: 4px;\n    z-index: 5;\n  }\n  .hour-hand {\n    width: 6px;\n    height: 80px;\n    background: #ef4444;\n    transform: translateX(-50%) rotate(0deg);\n  }\n  .minute-hand {\n    width: 4px;\n    height: 110px;\n    background: #4a9eff;\n    transform: translateX(-50%) rotate(0deg);\n  }\n  .second-hand {\n    width: 2px;\n    height: 125px;\n    background: #10b981;\n    transform: translateX(-50%) rotate(0deg);\n    z-index: 6;\n  }\n  .second-hand::after {\n    content: '';\n    position: absolute;\n    bottom: -15px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 4px;\n    height: 20px;\n    background: #10b981;\n    border-radius: 2px;\n  }\n  .time-display {\n    position: absolute;\n    bottom: 80px;\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 24px;\n    font-weight: 300;\n    color: #e0e0e0;\n    letter-spacing: 2px;\n    text-shadow: 0 0 10px rgba(74, 158, 255, 0.4);\n  }\n  .date-display {\n    position: absolute;\n    bottom: 45px;\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 14px;\n    color: #7c3aed;\n    text-shadow: 0 0 5px rgba(124, 58, 237, 0.5);\n  }\n  .brand {\n    position: absolute;\n    top: 50px;\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 12px;\n    color: #4a9eff;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n  }\n</style>\n</head>\n<body>\n<div class=\"watch-container\">\n  <div class=\"watch-face\" id=\"watchFace\">\n    <div class=\"brand\">PRECISION</div>\n    <div class=\"mark hour\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark hour\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark hour\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark hour\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"center-dot\"></div>\n    <div class=\"hand hour-hand\" id=\"hourHand\"></div>\n    <div class=\"hand minute-hand\" id=\"minuteHand\"></div>\n    <div class=\"hand second-hand\" id=\"secondHand\"></div>\n    <div class=\"time-display\" id=\"timeDisplay\">00:00:00</div>\n    <div class=\"date-display\" id=\"dateDisplay\">00</div>\n  </div>\n</div>\n\n<script>\nfunction updateWatch() {\n  const now = new Date();\n  const hours = now.getHours();\n  const minutes = now.getMinutes();\n  const seconds = now.getSeconds();\n  const milliseconds = now.getMilliseconds();\n  const date = now.getDate();\n  \n  const hourDegrees = ((hours % 12) + minutes / 60) * 30;\n  const minuteDegrees = (minutes + seconds / 60) * 6;\n  const secondDegrees = (seconds + milliseconds / 1000) * 6;\n  \n  document.getElementById('hourHand').style.transform = `translateX(-50%) rotate(${hourDegrees}deg)`;\n  document.getElementById('minuteHand').style.transform = `translateX(-50%) rotate(${minuteDegrees}deg)`;\n  document.getElementById('secondHand').style.transform = `translateX(-50%) rotate(${secondDegrees}deg)`;\n  \n  const timeStr = now.toLocaleTimeString('en-US', { hour12: false });\n  document.getElementById('timeDisplay').textContent = timeStr;\n  document.getElementById('dateDisplay').textContent = date.toString().padStart(2, '0');\n}\n\nupdateWatch();\nsetInterval(updateWatch, 50);\n\nconst watchFace = document.getElementById('watchFace');\nconst marks = document.querySelectorAll('.mark');\nmarks.forEach((mark, i) => {\n  mark.style.transform = `translateX(-50%) rotate(${i * 30}deg)`;\n});\n</script>\n</body>\n</html>",
    "createdAt": "2026-03-25T04:07:30.543Z"
