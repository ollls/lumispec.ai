    "html": "<!DOCTYPE html>\n<html><head>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { \n  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f0f1a 100%);\n  min-height: 100vh;\n  font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;\n  color: #e0e0e0;\n  padding: 20px;\n}\n.container { max-width: 1400px; margin: 0 auto; }\n.header { \n  text-align: center;\n  padding: 30px 20px;\n  background: linear-gradient(135deg, #4a9eff 0%, #7c3aed 100%);\n  border-radius: 20px;\n  margin-bottom: 30px;\n  box-shadow: 0 10px 40px rgba(74, 158, 255, 0.3);\n}\n.header h1 { \n  font-size: 2.5em;\n  margin-bottom: 10px;\n  text-shadow: 2px 2px 4px rgba(0,0,0,0.3);\n}\n.header .subtitle { \n  font-size: 1.2em;\n  opacity: 0.95;\n}\n.theater-info {\n  background: linear-gradient(135deg, #1e1e2f 0%, #2a2a4a 100%);\n  padding: 25px;\n  border-radius: 15px;\n  margin-bottom: 30px;\n  border: 2px solid #4a9eff;\n}\n.theater-info h2 { color: #4a9eff; margin-bottom: 15px; font-size: 1.8em; }\n.theater-details { display: flex; gap: 30px; flex-wrap: wrap; justify-content: center; }\n.detail-item { display: flex; align-items: center; gap: 8px; font-size: 1.1em; }\n.detail-icon { font-size: 1.4em; }\n.movies-grid { \n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n  gap: 25px;\n  margin-bottom: 30px;\n}\n.movie-card {\n  background: linear-gradient(145deg, #1e1e2f 0%, #25253a 100%);\n  border-radius: 15px;\n  padding: 25px;\n  transition: all 0.3s ease;\n  cursor: pointer;\n  border: 1px solid #2a2a4a;\n  position: relative;\n  overflow: hidden;\n}\n.movie-card:hover { \n  transform: translateY(-8px);\n  box-shadow: 0 15px 35px rgba(74, 158, 255, 0.4);\n  border-color: #4a9eff;\n}\n.movie-card::before {\n  content: '';\n  position: absolute;\n  top: 0; left: 0; right: 0; height: 3px;\n  background: linear-gradient(90deg, #4a9eff, #7c3aed);\n}\n.movie-title {\n  font-size: 1.4em;\n  font-weight: bold;\n  margin-bottom: 10px;\n  color: #fff;\n}\n.movie-meta {\n  display: flex;\n  gap: 12px;\n  margin-bottom: 15px;\n  flex-wrap: wrap;\n}\n.badge {\n  padding: 4px 12px;\n  border-radius: 20px;\n  font-size: 0.85em;\n  font-weight: 600;\n}\n.badge-gp { background: #10b981; color: white; }\n.badge-pg { background: #3b82f6; color: white; }\n.badge-r { background: #ef4444; color: white; }\n.badge-imax { background: #7c3aed; color: white; }\n.badge-rpx { background: #f59e0b; color: white; }\n.showtimes { \n  display: flex;\n  gap: 10px;\n  flex-wrap: wrap;\n  margin-top: 15px;\n}\n.showtime-btn {\n  padding: 8px 20px;\n  background: #4a9eff;\n  color: white;\n  border: none;\n  border-radius: 25px;\n  cursor: pointer;\n  transition: all 0.2s;\n  font-weight: 600;\n}\n.showtime-btn:hover { background: #7c3aed; transform: scale(1.05); }\n.thriller .showtime-btn:hover { background: #ef4444; }\n.adventure .showtime-btn:hover { background: #10b981; }\n.comedy .showtime-btn:hover { background: #f59e0b; }\n.footer { \n  text-align: center;\n  padding: 20px;\n  border-top: 1px solid #2a2a4a;\n  margin-top: 30px;\n  opacity: 0.8;\n}\n@media (max-width: 768px) {\n  .header h1 { font-size: 1.8em; }\n  .movies-grid { grid-template-columns: 1fr; }\n  .theater-details { flex-direction: column; align-items: center; gap: 10px; }\n}\n</style>\n</head><body>\n<div class=\"container\">\n  <div class=\"header\">\n    <h1>🎬 Oakland Park Movie Schedule</h1>\n    <p class=\"subtitle\">Showing at Regal Cypress Creek Station</p>\n  </div>\n  \n  <div class=\"theater-info\">\n    <h2>📍 Nearest Regal Theatre</h2>\n    <div class=\"theater-details\">\n      <div class=\"detail-item\"><span class=\"detail-icon\">🏢</span> Regal Cypress Creek Station</div>\n      <div class=\"detail-item\"><span class=\"detail-icon\">🗺️</span> 6415 N Andrews Ave, Fort Lauderdale, FL 33309</div>\n      <div class=\"detail-item\"><span class=\"detail-icon\">🚗</span> ~5 min from Oakland Park</div>\n      <div class=\"detail-item\"><span class=\"detail-icon\">📞</span> (844) 462-7342</div>\n    </div>\n  </div>\n\n  <div class=\"movies-grid\">\n    <div class=\"movie-card thriller\">\n      <div class=\"movie-title\">🍑 GOAT</div>\n      <div class=\"movie-meta\">\n        <span class=\"badge badge-gp\">PG</span>\n        <span class=\"badge badge-imax\">1h 40m</span>\n      </div>\n      <div class=\"showtimes\">\n        <button class=\"showtime-btn\">1:30 PM</button>\n        <button class=\"showtime-btn\">4:10 PM</button>\n        <button class=\"showtime-btn\">7:00 PM</button>\n      </div>\n    </div>\n\n    <div class=\"movie-card adventure\">\n      <div class=\"movie-title\">🌠 Project Hail Mary</div>\n      <div class=\"movie-meta\">\n        <span class=\"badge badge-pg\">PG-13</span>\n        <span class=\"badge badge-imax\">IMAX available</span>\n      </div>\n      <div class=\"showtimes\">\n        <button class=\"showtime-btn\">5:50 PM</button>\n        <button class=\"showtime-btn\">8:50 PM</button>\n      </div>\n    </div>\n\n    <div class=\"movie-card comedy\">\n      <div class=\"movie-title\">🎭 Ready or Not: Here I Come</div>\n      <div class=\"movie-meta\">\n        <span class=\"badge badge-pg\">PG-13</span>\n        <span class=\"badge badge-rpx\">RPX available</span>\n      </div>\n      <div class=\"showtimes\">\n        <button class=\"showtime-btn\">1:40 PM</button>\n        <button class=\"showtime-btn\">4:20 PM</button>\n        <button class=\"showtime-btn\">7:30 PM RPX</button>\n        <button class=\"showtime-btn\">10:00 PM</button>\n      </div>\n    </div>\n\n    <div class=\"movie-card thriller\">\n      <div class=\"movie-title\">🗡️ Scream 7</div>\n      <div class=\"movie-meta\">\n        <span class=\"badge badge-r\">R</span>\n        <span class=\"badge badge-rpx\">RPX available</span>\n      </div>\n      <div class=\"showtimes\">\n        <button class=\"showtime-btn\">10:45 AM</button>\n        <button class=\"showtime-btn\">10:45 PM RPX</button>\n      </div>\n    </div>\n\n    <div class=\"movie-card adventure\">\n      <div class=\"movie-title\">🕺 The Rocky Horror Picture Show</div>\n      <div class=\"movie-meta\">\n        <span class=\"badge badge-gp\">Classic</span>\n        <span class=\"badge badge-rpx\">Midnight Screening</span>\n      </div>\n      <div class=\"showtimes\">\n        <button class=\"showtime-btn\">11:55 PM</button>\n      </div>\n    </div>\n\n    <div class=\"movie-card thriller\">\n      <div class=\"movie-title\">💝 Reminders of Him</div>\n      <div class=\"movie-meta\">\n        <span class=\"badge badge-pg\">PG-13</span>\n      </div>\n      <div class=\"showtimes\">\n        <button class=\"showtime-btn\">1:40 PM</button>\n        <button class=\"showtime-btn\">7:20 PM</button>\n        <button class=\"showtime-btn\">9:50 PM</button>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"footer\">\n    <p>⚡ All showtimes subject to change. Book tickets at regmovies.com</p>\n    <p>🎟️ Reserve your seats in advance for best selection!</p>\n  </div>\n</div>\n<script>\ndocument.querySelectorAll('.showtime-btn').forEach(btn => {\n  btn.addEventListener('click', function() {\n    const time = this.textContent;\n    alert(`💺 Booking prompt:\\n\\nMovie: ${this.closest('.movie-card').querySelector('.movie-title').textContent}\\nShowtime: ${time}\\n\\nRedirecting to regmovies.com...`);\n  });\n});\nwindow.parent.postMessage({ type: 'resize', height: document.body.scrollHeight }, '*');\n</script>\n</body></html>",
    "createdAt": "2026-03-21T04:38:36.536Z"
  },
