  {
    "id": "6259b310-d496-490e-bff6-db51846bbe6a",
    "name": "Portfolio Dashboard",
    "type": "html",
    "html": "<!DOCTYPE html>\n<html><head>\n<style>\n* { box-sizing: border-box; }\nbody { margin: 0; padding: 20px; background: #1a1a2e; color: #e0e0e0; font-family: system-ui, -apple-system, sans-serif; }\n.container { max-width: 1400px; margin: 0 auto; }\nh1 { color: #4a9eff; margin-bottom: 24px; font-size: 28px; }\nh2 { color: #4a9eff; margin-bottom: 16px; font-size: 20px; }\n.cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 20px; margin-bottom: 30px; }\n.card { background: #16213e; border-radius: 12px; padding: 20px; border: 1px solid #2a2a4a; }\n.card h2 { color: #7c3aed; margin: 0 0 16px 0; font-size: 18px; border-bottom: 1px solid #2a2a4a; padding-bottom: 12px; }\n.row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #2a2a4a; }\n.row:last-child { border-bottom: none; }\n.label { color: #a0a0a0; }\n.value { font-weight: 600; }\n.pos-table { width: 100%; border-collapse: collapse; font-size: 13px; }\n.pos-table th { text-align: left; padding: 8px; background: #1a1a2e; color: #4a9eff; font-weight: 600; }\n.pos-table td { padding: 8px; border-bottom: 1px solid #2a2a4a; }\n.pos-table tr:hover { background: #2a2a4a; }\n.pos-table td:last-child, .pos-table th:last-child { text-align: right; }\n.pos-table tr:nth-child(even) { background: #1a1a2e; }\n.pos-table tfoot td { font-weight: 700; border-top: 2px solid #4a9eff; background: #16213e; }\n.green { color: #10b981; }\n.red { color: #ef4444; }\n.badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }\n.badge-optn { background: #7c3aed; color: white; }\n.badge-eq { background: #4a9eff; color: white; }\n.loading { text-align: center; padding: 40px; color: #7c3aed; font-size: 18px; }\n.error { text-align: center; padding: 40px; color: #ef4444; font-size: 16px; }\n</style>\n</head><body>\n<div class=\"container\" id=\"root\">\n<div class=\"loading\">Loading portfolio data...</div>\n</div>\n<script>\nconst FILE = \"portfolio.json\";\nfunction fmt(n){return typeof n===\"number\"?n.toLocaleString(\"en-US\",{style:\"currency\",currency:\"USD\"}):n||\"—\";}\nfunction pct(n){return typeof n===\"number\"?(n>=0?\"+\":\"\")+n.toFixed(2)+\"%\":\"—\";}\nfunction cls(n){return typeof n===\"number\"?(n>=0?\"green\":\"red\"):\"\";}\nfunction badge(pos){\n  if(!pos.type||pos.type===\"EQ\")return`<span class=\"badge badge-eq\">EQ</span>`;\n  return`<span class=\"badge badge-optn\">${pos.type} ${pos.strike?(\"$\"+pos.strike):\"\"}</span>`;\n}\nfunction renderAccount(acct){\n  return`<div class=\"card\">\n<h2>${acct.name||\"Account\"}</h2>\n<div class=\"row\"><span class=\"label\">Account Type</span><span class=\"value\">${acct.accountType||\"—\"}</span></div>\n<div class=\"row\"><span class=\"label\">Total Value</span><span class=\"value\">${fmt(acct.totalValue)}</span></div>\n<div class=\"row\"><span class=\"label\">Cash Balance</span><span class=\"value\">${fmt(acct.cashBalance)}</span></div>\n<div class=\"row\"><span class=\"label\">Buying Power</span><span class=\"value\">${fmt(acct.buyingPower)}</span></div>\n</div>`;\n}\nfunction renderPositions(title,positions){\n  if(!positions||!positions.length)return\"\";\n  let totalCost=0,totalMarket=0,totalGain=0;\n  const rows=positions.map(p=>{\n    const cost=p.cost||0,market=p.market||0,gain=p.gain||(market-cost);\n    totalCost+=Math.abs(cost);totalMarket+=Math.abs(market);totalGain+=gain;\n    const pctVal=cost!==0?((gain/Math.abs(cost))*100):0;\n    return`<tr><td>${p.symbol}</td><td>${badge(p)}</td><td>${p.qty}</td>\n<td>${fmt(cost)}</td><td>${fmt(market)}</td>\n<td class=\"${cls(gain)}\">${gain>=0?\"+\":\"\"}${fmt(Math.abs(gain))}</td>\n<td class=\"${cls(pctVal)}\">${pct(pctVal)}</td></tr>`;\n  }).join(\"\");\n  const totalPct=totalCost!==0?((totalGain/totalCost)*100):0;\n  return`<h2>${title}</h2>\n<div style=\"overflow-x:auto;margin-bottom:20px\">\n<table class=\"pos-table\">\n<thead><tr><th>Symbol</th><th>Type</th><th>Qty</th><th>Cost</th><th>Market</th><th>Gain/Loss</th><th>%</th></tr></thead>\n<tbody>${rows}</tbody>\n<tfoot><tr><td colspan=\"3\"><strong>Total</strong></td>\n<td>${fmt(totalCost)}</td><td>${fmt(totalMarket)}</td>\n<td class=\"${cls(totalGain)}\">${totalGain>=0?\"+\":\"\"}${fmt(Math.abs(totalGain))}</td>\n<td class=\"${cls(totalPct)}\">${pct(totalPct)}</td></tr></tfoot>\n</table></div>`;\n}\nasync function load(){\n  try{\n    const res=await fetch(\"/files/\"+FILE);\n    if(!res.ok)throw new Error(\"File not found: \"+FILE+\" (\"+res.status+\")\");\n    const data=await res.json();\n    const root=document.getElementById(\"root\");\n    let html=\"<h1>Portfolio Dashboard</h1>\";\n    if(data.accounts&&data.accounts.length){\n      html+=`<div class=\"cards\">${data.accounts.map(renderAccount).join(\"\")}</div>`;\n    }\n    if(data.positions){\n      for(const[title,positions] of Object.entries(data.positions)){\n        html+=renderPositions(title,positions);\n      }\n    }\n    root.innerHTML=html;\n  }catch(e){\n    document.getElementById(\"root\").innerHTML=`<div class=\"error\">Error: ${e.message}<br><br>Expected /files/${FILE} with format:<br><pre style=\"text-align:left;color:#a0a0a0;font-size:12px\">{\"accounts\":[{\"name\":\"...\",\"totalValue\":0,\"cashBalance\":0,\"buyingPower\":0}],\n\"positions\":{\"Account Name\":[{\"symbol\":\"AAPL\",\"type\":\"EQ\",\"qty\":100,\"cost\":15000,\"market\":17000,\"gain\":2000}]}}</pre></div>`;\n  }\n}\nload();\n</script>\n</body></html>",
    "createdAt": "2026-03-26T16:27:16.553Z"
  },
  {
    "id": "d2400070-06e1-4c4e-bb98-803b73a5edb8",
    "name": "Beautiful Watch",
    "type": "html",
    "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Analog Watch</title>\n<style>\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body {\n    background: #1a1a2e;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    min-height: 100vh;\n    font-family: system-ui, -apple-system, sans-serif;\n  }\n  .watch-container {\n    background: #0f0f1a;\n    border: 8px solid #2a2a4a;\n    border-radius: 50%;\n    padding: 40px;\n    position: relative;\n    box-shadow: 0 0 60px rgba(74, 158, 255, 0.15), inset 0 0 40px rgba(0,0,0,0.5);\n  }\n  .watch-face {\n    width: 320px;\n    height: 320px;\n    background: radial-gradient(circle at 30% 30%, #1e1e3a, #0a0a15);\n    border-radius: 50%;\n    position: relative;\n    box-shadow: inset 0 0 20px rgba(0,0,0,0.6);\n  }\n  .mark {\n    position: absolute;\n    width: 4px;\n    height: 20px;\n    background: #4a9eff;\n    left: 50%;\n    top: 10px;\n    transform-origin: 50% 150px;\n    border-radius: 2px;\n  }\n  .mark.hour {\n    width: 6px;\n    height: 30px;\n    background: #7c3aed;\n  }\n  .mark.hour:nth-child(1), .mark.hour:nth-child(4), .mark.hour:nth-child(7), .mark.hour:nth-child(10) {\n    width: 8px;\n    height: 38px;\n    background: #10b981;\n  }\n  .center-dot {\n    position: absolute;\n    width: 12px;\n    height: 12px;\n    background: #ef4444;\n    border-radius: 50%;\n    left: 50%;\n    top: 50%;\n    transform: translate(-50%, -50%);\n    z-index: 10;\n    box-shadow: 0 0 8px rgba(239, 68, 68, 0.6);\n  }\n  .hand {\n    position: absolute;\n    left: 50%;\n    bottom: 50%;\n    transform-origin: 50% 100%;\n    border-radius: 4px;\n    z-index: 5;\n  }\n  .hour-hand {\n    width: 6px;\n    height: 80px;\n    background: #ef4444;\n    transform: translateX(-50%) rotate(0deg);\n  }\n  .minute-hand {\n    width: 4px;\n    height: 110px;\n    background: #4a9eff;\n    transform: translateX(-50%) rotate(0deg);\n  }\n  .second-hand {\n    width: 2px;\n    height: 125px;\n    background: #10b981;\n    transform: translateX(-50%) rotate(0deg);\n    z-index: 6;\n  }\n  .second-hand::after {\n    content: '';\n    position: absolute;\n    bottom: -15px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 4px;\n    height: 20px;\n    background: #10b981;\n    border-radius: 2px;\n  }\n  .time-display {\n    position: absolute;\n    bottom: 80px;\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 24px;\n    font-weight: 300;\n    color: #e0e0e0;\n    letter-spacing: 2px;\n    text-shadow: 0 0 10px rgba(74, 158, 255, 0.4);\n  }\n  .date-display {\n    position: absolute;\n    bottom: 45px;\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 14px;\n    color: #7c3aed;\n    text-shadow: 0 0 5px rgba(124, 58, 237, 0.5);\n  }\n  .brand {\n    position: absolute;\n    top: 50px;\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 12px;\n    color: #4a9eff;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n  }\n</style>\n</head>\n<body>\n<div class=\"watch-container\">\n  <div class=\"watch-face\" id=\"watchFace\">\n    <div class=\"brand\">PRECISION</div>\n    <div class=\"mark hour\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark hour\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark hour\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark hour\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"mark\"></div>\n    <div class=\"center-dot\"></div>\n    <div class=\"hand hour-hand\" id=\"hourHand\"></div>\n    <div class=\"hand minute-hand\" id=\"minuteHand\"></div>\n    <div class=\"hand second-hand\" id=\"secondHand\"></div>\n    <div class=\"time-display\" id=\"timeDisplay\">00:00:00</div>\n    <div class=\"date-display\" id=\"dateDisplay\">00</div>\n  </div>\n</div>\n\n<script>\nfunction updateWatch() {\n  const now = new Date();\n  const hours = now.getHours();\n  const minutes = now.getMinutes();\n  const seconds = now.getSeconds();\n  const milliseconds = now.getMilliseconds();\n  const date = now.getDate();\n  \n  const hourDegrees = ((hours % 12) + minutes / 60) * 30;\n  const minuteDegrees = (minutes + seconds / 60) * 6;\n  const secondDegrees = (seconds + milliseconds / 1000) * 6;\n  \n  document.getElementById('hourHand').style.transform = `translateX(-50%) rotate(${hourDegrees}deg)`;\n  document.getElementById('minuteHand').style.transform = `translateX(-50%) rotate(${minuteDegrees}deg)`;\n  document.getElementById('secondHand').style.transform = `translateX(-50%) rotate(${secondDegrees}deg)`;\n  \n  const timeStr = now.toLocaleTimeString('en-US', { hour12: false });\n  document.getElementById('timeDisplay').textContent = timeStr;\n  document.getElementById('dateDisplay').textContent = date.toString().padStart(2, '0');\n}\n\nupdateWatch();\nsetInterval(updateWatch, 50);\n\nconst watchFace = document.getElementById('watchFace');\nconst marks = document.querySelectorAll('.mark');\nmarks.forEach((mark, i) => {\n  mark.style.transform = `translateX(-50%) rotate(${i * 30}deg)`;\n});\n</script>\n</body>\n</html>",
    "createdAt": "2026-03-25T04:07:30.543Z"
  },
  {
    "id": "171eddb7-0150-408a-a7a7-e37304f0b39d",
    "name": "Watch",
    "type": "html",
    "html": "<!DOCTYPE html>\n<html>\n<head>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  min-height: 100vh;\n  background: #1a1a2e;\n  font-family: system-ui, sans-serif;\n  color: #e0e0e0;\n}\n.clock-container {\n  position: relative;\n  width: 400px;\n  height: 400px;\n  border-radius: 50%;\n  background: linear-gradient(145deg, #16213e, #0f0f23);\n  box-shadow: \n    0 0 60px rgba(74, 158, 255, 0.2),\n    inset 0 0 40px rgba(0, 0, 0, 0.5);\n  display: flex;\n  justify-content: center;\n  align-items: center;\n}\n.clock-face {\n  position: relative;\n  width: 360px;\n  height: 360px;\n  border-radius: 50%;\n  border: 4px solid #2a2a4a;\n}\n.mark {\n  position: absolute;\n  width: 4px;\n  height: 15px;\n  background: #4a9eff;\n  left: 50%;\n  top: 10px;\n  transform-origin: 50% 170px;\n  border-radius: 2px;\n}\n.mark.major {\n  width: 6px;\n  height: 25px;\n  background: #7c3aed;\n}\n.center-dot {\n  position: absolute;\n  width: 16px;\n  height: 16px;\n  background: #ef4444;\n  border-radius: 50%;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  z-index: 10;\n  box-shadow: 0 0 10px rgba(239, 68, 68, 0.5);\n}\n.hour-hand, .minute-hand, .second-hand {\n  position: absolute;\n  left: 50%;\n  bottom: 50%;\n  transform-origin: 50% 100%;\n  border-radius: 4px;\n  transition: transform 0.05s cubic-bezier(0.4, 2.08, 0.55, 0.44);\n}\n.hour-hand {\n  width: 8px;\n  height: 80px;\n  background: #4a9eff;\n  margin-left: -4px;\n}\n.minute-hand {\n  width: 6px;\n  height: 110px;\n  background: #7c3aed;\n  margin-left: -3px;\n}\n.second-hand {\n  width: 2px;\n  height: 140px;\n  background: #ef4444;\n  margin-left: -1px;\n}\n.second-hand::after {\n  content: '';\n  position: absolute;\n  width: 8px;\n  height: 25px;\n  background: #ef4444;\n  left: 50%;\n  bottom: -25px;\n  transform: translateX(-50%);\n  border-radius: 2px;\n}\n.time-display {\n  position: absolute;\n  bottom: 60px;\n  font-size: 28px;\n  font-weight: 300;\n  letter-spacing: 2px;\n  color: #e0e0e0;\n  text-shadow: 0 0 20px rgba(74, 158, 255, 0.3);\n}\n.date-display {\n  position: absolute;\n  bottom: 20px;\n  font-size: 16px;\n  color: #7c3aed;\n}\n</style>\n</head>\n<body>\n<div class=\"clock-container\">\n  <div class=\"clock-face\" id=\"clockFace\"></div>\n  <div class=\"center-dot\"></div>\n  <div class=\"hour-hand\" id=\"hourHand\"></div>\n  <div class=\"minute-hand\" id=\"minuteHand\"></div>\n  <div class=\"second-hand\" id=\"secondHand\"></div>\n  <div class=\"time-display\" id=\"timeDisplay\">00:00:00</div>\n  <div class=\"date-display\" id=\"dateDisplay\"></div>\n</div>\n\n<script>\nconst clockFace = document.getElementById('clockFace');\nconst hourHand = document.getElementById('hourHand');\nconst minuteHand = document.getElementById('minuteHand');\nconst secondHand = document.getElementById('secondHand');\nconst timeDisplay = document.getElementById('timeDisplay');\nconst dateDisplay = document.getElementById('dateDisplay');\n\n// Create clock marks\nfor (let i = 0; i < 60; i++) {\n  const mark = document.createElement('div');\n  mark.className = i % 5 === 0 ? 'mark major' : 'mark';\n  mark.style.transform = `translateX(-50%) rotate(${i * 6}deg)`;\n  clockFace.appendChild(mark);\n}\n\nfunction updateClock() {\n  const now = new Date();\n  const hours = now.getHours() % 12;\n  const minutes = now.getMinutes();\n  const seconds = now.getSeconds();\n  const ms = now.getMilliseconds();\n  \n  const hourDeg = (hours * 30) + (minutes * 0.5);\n  const minuteDeg = (minutes * 6) + (seconds * 0.1);\n  const secondDeg = (seconds * 6) + (ms * 0.006);\n  \n  hourHand.style.transform = `translateX(-50%) rotate(${hourDeg}deg)`;\n  minuteHand.style.transform = `translateX(-50%) rotate(${minuteDeg}deg)`;\n  secondHand.style.transform = `translateX(-50%) rotate(${secondDeg}deg)`;\n  \n  const timeStr = now.toLocaleTimeString('en-US', { \n    hour12: false, \n    hour: '2-digit', \n    minute: '2-digit', \n    second: '2-digit' \n  });\n  timeDisplay.textContent = timeStr;\n  \n  const dateStr = now.toLocaleDateString('en-US', { \n    weekday: 'short', \n    month: 'short', \n    day: 'numeric' \n  });\n  dateDisplay.textContent = dateStr;\n}\n\nsetInterval(updateClock, 50);\nupdateClock();\n</script>\n</body>\n</html>",
    "createdAt": "2026-03-24T21:45:44.637Z"
  },
  {
    "id": "f4d5d195-fec9-47fe-9b30-43cecd0a5804",
    "name": "Next Week Options",
    "type": "html",
    "html": "<!DOCTYPE html>\n<html>\n<head>\n<script src=\"/lib/chart.min.js\"></script>\n<style>\n* { box-sizing: border-box; margin: 0; padding: 0; }\nbody { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #1a1a2e; color: #e0e0e0; padding: 20px; }\n.container { max-width: 1400px; margin: 0 auto; }\n.header { text-align: center; margin-bottom: 30px; }\n.header h1 { color: #4a9eff; font-size: 28px; margin-bottom: 8px; }\n.header .subtitle { color: #7c3aed; font-size: 16px; }\n.header .info { color: #10b981; font-size: 14px; margin-top: 5px; }\n.grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }\n.card { background: #16213e; border-radius: 12px; padding: 20px; border: 1px solid #2a2a4a; }\n.card h3 { color: #4a9eff; margin-bottom: 15px; font-size: 18px; }\n.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; }\n.stat { text-align: center; padding: 15px; background: #1a1a2e; border-radius: 8px; }\n.stat .value { font-size: 24px; font-weight: bold; color: #10b981; }\n.stat .label { font-size: 12px; color: #7c3aed; margin-top: 5px; }\n.table-container { overflow-x: auto; border-radius: 8px; background: #1a1a2e; }\ntable { width: 100%; border-collapse: collapse; white-space: nowrap; }\nth, td { padding: 12px 15px; text-align: right; }\nth { background: #7c3aed; color: #fff; text-align: center; font-weight: 600; }\ntd { border-bottom: 1px solid #2a2a4a; }\ntr:hover { background: #2a2a4a; }\ntr:nth-child(even) { background: #1a1a2e; }\ntr:nth-child(odd) { background: #16213e; }\n.strike-col { text-align: center !important; color: #4a9eff; font-weight: bold; }\n.positive { color: #10b981; }\n.negative { color: #ef4444; }\n.chart-container { position: relative; height: 300px; width: 100%; }\n</style>\n</head>\n<body>\n<div class=\"container\">\n<div class=\"header\">\n<h1>📊 INTC Call Options - Next Week</h1>\n<div class=\"subtitle\">Expiration: March 27, 2026 | Stock Price: $43.87</div>\n<div class=\"info\">Sorted by Volume • Top 30 Calls by Trading Activity</div>\n</div>\n\n<div class=\"grid\">\n<div class=\"card\">\n<h3>🎯 Volume Leaders</h3>\n<div class=\"stats-grid\">\n<div class=\"stat\"><div class=\"value\" id=\"maxVol\">-</div><div class=\"label\">Max Volume</div></div>\n<div class=\"stat\"><div class=\"value\" id=\"avgVol\">-</div><div class=\"label\">Avg Volume</div></div>\n<div class=\"stat\"><div class=\"value\" id=\"totalOI\">-</div><div class=\"label\">Total OI</div></div>\n<div class=\"stat\"><div class=\"value\" id=\"maxIV\">-</div><div class=\"label\">Max IV</div></div>\n</div>\n</div>\n\n<div class=\"card\">\n<h3>💰 Pricing Info</h3>\n<div class=\"stats-grid\">\n<div class=\"stat\"><div class=\"value\" id=\"bid\">-</div><div class=\"label\">Bid</div></div>\n<div class=\"stat\"><div class=\"value\" id=\"ask\">-</div><div class=\"label\">Ask</div></div>\n<div class=\"stat\"><div class=\"value\" id=\"last\">-</div><div class=\"label\">Last</div></div>\n<div class=\"stat\"><div class=\"value\" id=\"change\">-</div><div class=\"label\">Change %</div></div>\n</div>\n</div>\n</div>\n\n<div class=\"card\" style=\"margin-bottom: 20px;\">\n<h3>📈 Volume Distribution Chart</h3>\n<div class=\"chart-container\">\n<canvas id=\"volumeChart\"></canvas>\n</div>\n</div>\n\n<div class=\"card\">\n<h3>📋 All Call Options by Volume (Top 30)</h3>\n<div class=\"table-container\">\n<table id=\"optionsTable\">\n<thead>\n<tr>\n<th>Strike</th>\n<th>Last</th>\n<th>Bid</th>\n<th>Ask</th>\n<th>Volume</th>\n<th>OI</th>\n<th>IV</th>\n<th>Delta</th>\n</tr>\n</thead>\n<tbody id=\"tableBody\"></tbody>\n</table>\n</div>\n</div>\n</div>\n\n<script>\nconst STOCK_INFO = {\n  current: 43.87,\n  bid: 43.72,\n  ask: 44.12,\n  last: 43.87,\n  change: -0.15\n};\n\ndocument.getElementById('bid').textContent = STOCK_INFO.bid.toFixed(2);\ndocument.getElementById('ask').textContent = STOCK_INFO.ask.toFixed(2);\ndocument.getElementById('last').textContent = STOCK_INFO.last.toFixed(2);\ndocument.getElementById('change').textContent = (STOCK_INFO.change / (STOCK_INFO.current + Math.abs(STOCK_INFO.change)) * 100).toFixed(2) + '%';\n\nconst CSV_FILE = 'INTC_calls_mar27.csv';\nlet OPTIONS_DATA = [];\n\nasync function loadCSV(url) {\n  if (!url.startsWith('/')) url = '/files/' + url;\n  try {\n    const res = await fetch(url);\n    const text = await res.text();\n    const rows = text.trim().split('\\n');\n    const headers = rows[0].split(',').map(h => h.trim());\n    console.log('CSV headers:', headers, 'rows:', rows.length - 1);\n    return rows.slice(1).map(r => { \n      const v = r.split(','); \n      return Object.fromEntries(headers.map((h,i) => [h, v[i]?.trim() || ''])); \n    });\n  } catch(e) {\n    document.body.innerHTML = '<pre style=\"color:red\">Error loading CSV: ' + e.message + '</pre>';\n    throw e;\n  }\n}\n\nasync function init() {\n  try {\n    OPTIONS_DATA = await loadCSV(CSV_FILE);\n    const stocks = OPTIONS_DATA.filter(d => d.Symbol === 'INTC' && d.Type === 'Call').sort((a,b) => parseInt(b.Volume) - parseInt(a.Volume));\n    \n    // Stats\n    const volumes = stocks.map(d => parseInt(d.Volume));\n    const maxVol = Math.max(...volumes);\n    const avgVol = Math.round(volumes.reduce((a, b) => a + b, 0) / volumes.length);\n    const totalOI = stocks.reduce((sum, d) => sum + parseInt(d['Open Interest']), 0);\n    const maxIV = Math.max(...stocks.map(d => parseFloat(d.IV)));\n\n    document.getElementById('maxVol').textContent = maxVol.toLocaleString();\n    document.getElementById('avgVol').textContent = avgVol.toLocaleString();\n    document.getElementById('totalOI').textContent = totalOI.toLocaleString();\n    document.getElementById('maxIV').textContent = (maxIV * 100).toFixed(2) + '%';\n\n    // Chart\n    const ctx = document.getElementById('volumeChart').getContext('2d');\n    new Chart(ctx, {\n      type: 'bar',\n      data: {\n        labels: stocks.map(d => d.Strike),\n        datasets: [{\n          label: 'Volume',\n          data: volumes,\n          backgroundColor: 'rgba(74, 158, 255, 0.8)',\n          borderColor: '#4a9eff',\n          borderWidth: 1\n        }]\n      },\n      options: {\n        responsive: true,\n        maintainAspectRatio: false,\n        plugins: { legend: { display: false } },\n        scales: {\n          y: { beginAtZero: true, grid: { color: '#2a2a4a' }, ticks: { color: '#e0e0e0' } },\n          x: { grid: { color: '#2a2a4a' }, ticks: { color: '#e0e0e0' } }\n        }\n      }\n    });\n\n    // Table\n    const tbody = document.getElementById('tableBody');\n    stocks.forEach(d => {\n      const tr = document.createElement('tr');\n      tr.innerHTML = `\n        <td class=\"strike-col\">${d.Strike}</td>\n        <td>${parseFloat(d.Last).toFixed(2)}</td>\n        <td>${parseFloat(d.Bid).toFixed(2)}</td>\n        <td>${parseFloat(d.Ask).toFixed(2)}</td>\n        <td>${parseInt(d.Volume).toLocaleString()}</td>\n        <td>${parseInt(d['Open Interest']).toLocaleString()}</td>\n        <td>${(parseFloat(d.IV) * 100).toFixed(2)}%</td>\n        <td>${parseFloat(d.Delta).toFixed(3)}</td>\n      `;\n      tbody.appendChild(tr);\n    });\n  } catch(e) {\n    console.error('Init error:', e);\n    document.body.innerHTML = '<pre style=\"color:red\">Error initializing: ' + e.message + '</pre>';\n  }\n}\n\ninit();\n</script>\n</body>\n</html>",
    "createdAt": "2026-03-21T04:44:45.188Z"
  },
