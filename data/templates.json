    "html": "<!DOCTYPE html>\n<html><head>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { \n  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f0f1a 100%);\n  min-height: 100vh;\n  font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;\n  color: #e0e0e0;\n  padding: 20px;\n}\n.container { max-width: 1400px; margin: 0 auto; }\n.header { \n  text-align: center;\n  padding: 30px 20px;\n  background: linear-gradient(135deg, #4a9eff 0%, #7c3aed 100%);\n  border-radius: 20px;\n  margin-bottom: 30px;\n  box-shadow: 0 10px 40px rgba(74, 158, 255, 0.3);\n}\n.header h1 { \n  font-size: 2.5em;\n  margin-bottom: 10px;\n  text-shadow: 2px 2px 4px rgba(0,0,0,0.3);\n}\n.header .subtitle { \n  font-size: 1.2em;\n  opacity: 0.95;\n}\n.theater-info {\n  background: linear-gradient(135deg, #1e1e2f 0%, #2a2a4a 100%);\n  padding: 25px;\n  border-radius: 15px;\n  margin-bottom: 30px;\n  border: 2px solid #4a9eff;\n}\n.theater-info h2 { color: #4a9eff; margin-bottom: 15px; font-size: 1.8em; }\n.theater-details { display: flex; gap: 30px; flex-wrap: wrap; justify-content: center; }\n.detail-item { display: flex; align-items: center; gap: 8px; font-size: 1.1em; }\n.detail-icon { font-size: 1.4em; }\n.movies-grid { \n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n  gap: 25px;\n  margin-bottom: 30px;\n}\n.movie-card {\n  background: linear-gradient(145deg, #1e1e2f 0%, #25253a 100%);\n  border-radius: 15px;\n  padding: 25px;\n  transition: all 0.3s ease;\n  cursor: pointer;\n  border: 1px solid #2a2a4a;\n  position: relative;\n  overflow: hidden;\n}\n.movie-card:hover { \n  transform: translateY(-8px);\n  box-shadow: 0 15px 35px rgba(74, 158, 255, 0.4);\n  border-color: #4a9eff;\n}\n.movie-card::before {\n  content: '';\n  position: absolute;\n  top: 0; left: 0; right: 0; height: 3px;\n  background: linear-gradient(90deg, #4a9eff, #7c3aed);\n}\n.movie-title {\n  font-size: 1.4em;\n  font-weight: bold;\n  margin-bottom: 10px;\n  color: #fff;\n}\n.movie-meta {\n  display: flex;\n  gap: 12px;\n  margin-bottom: 15px;\n  flex-wrap: wrap;\n}\n.badge {\n  padding: 4px 12px;\n  border-radius: 20px;\n  font-size: 0.85em;\n  font-weight: 600;\n}\n.badge-gp { background: #10b981; color: white; }\n.badge-pg { background: #3b82f6; color: white; }\n.badge-r { background: #ef4444; color: white; }\n.badge-imax { background: #7c3aed; color: white; }\n.badge-rpx { background: #f59e0b; color: white; }\n.showtimes { \n  display: flex;\n  gap: 10px;\n  flex-wrap: wrap;\n  margin-top: 15px;\n}\n.showtime-btn {\n  padding: 8px 20px;\n  background: #4a9eff;\n  color: white;\n  border: none;\n  border-radius: 25px;\n  cursor: pointer;\n  transition: all 0.2s;\n  font-weight: 600;\n}\n.showtime-btn:hover { background: #7c3aed; transform: scale(1.05); }\n.thriller .showtime-btn:hover { background: #ef4444; }\n.adventure .showtime-btn:hover { background: #10b981; }\n.comedy .showtime-btn:hover { background: #f59e0b; }\n.footer { \n  text-align: center;\n  padding: 20px;\n  border-top: 1px solid #2a2a4a;\n  margin-top: 30px;\n  opacity: 0.8;\n}\n.error-message {\n  background: #ef4444;\n  color: white;\n  padding: 15px;\n  border-radius: 8px;\n  text-align: center;\n  margin-bottom: 20px;\n}\n@media (max-width: 768px) {\n  .header h1 { font-size: 1.8em; }\n  .movies-grid { grid-template-columns: 1fr; }\n  .theater-details { flex-direction: column; align-items: center; gap: 10px; }\n}\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <div class=\"header\">\n    <h1 id=\"header-title\">Loading Schedule...</h1>\n    <p class=\"subtitle\" id=\"header-subtitle\">Loading Theatre Info...</p>\n  </div>\n  \n  <div id=\"loading-overlay\" class=\"error-message\" style=\"display:none; background: #f59e0b;\">Loading data from CSV...</div>\n  \n  <div class=\"theater-info\" id=\"theater-info-section\" style=\"display:none;\">\n    <h2>📍 Nearest Regal Theatre</h2>\n    <div class=\"theater-details\" id=\"theater-details\">\n      <!-- Populated via JS -->\n    </div>\n  </div>\n\n  <div class=\"movies-grid\" id=\"movies-grid\">\n    <!-- Populated via JS -->\n  </div>\n\n  <div class=\"footer\">\n    <p id=\"footer-text\">⚡ All showtimes subject to change. Book tickets at regmovies.com</p>\n    <p>🎟️ Reserve your seats in advance for best selection!</p>\n  </div>\n</div>\n<script>\nconst FILES = ['theater_info.json', 'movies.csv'];\nlet theaterData = [];\nlet moviesData = [];\nconst API_BASE = '/files';\n\nasync function loadTheaterData() {\n  try {\n    const response = await fetch(`${API_BASE}/theater_info.json`);\n    if (!response.ok) throw new Error('Theater data missing');\n    theaterData = await response.json();\n    document.getElementById('header-title').textContent = theaterData.title || \"🎬 Movie Schedule\";\n    document.getElementById('header-subtitle').textContent = `Showing at ${theaterData.theatreName || 'Local Theatre'}`;\n    document.getElementById('theater-info-section').style.display = 'block';\n    renderTheaterDetails();\n  } catch (e) {\n    console.error(\"Theater fetch failed\", e);\n    document.getElementById('loading-overlay').style.display = 'block';\n    document.getElementById('loading-overlay').textContent = \"Could not load theatre details.\";\n  }\n}\n\nasync function loadMoviesData() {\n  try {\n    const response = await fetch(`${API_BASE}/movies.csv`);\n    if (!response.ok) throw new Error('Movies data missing');\n    const csvText = await response.text();\n    moviesData = parseCSV(csvText);\n    renderMovies();\n    window.parent.postMessage({type:'resize',height:document.body.scrollHeight},'*');\n  } catch (e) {\n    console.error(\"Movies fetch failed\", e);\n    document.getElementById('loading-overlay').style.display = 'block';\n    document.getElementById('loading-overlay').textContent = \"Could not load movie schedule.\";\n  }\n}\n\nfunction parseCSV(text) {\n  const lines = text.trim().split('\\n');\n  const headers = lines[0].split(',').map(h => h.trim().replace(/\"/g, ''));\n  return lines.slice(1).map(line => {\n    const values = line.split(/,(?=(?:(?:[^\"]*\"){2})*[^\"]*$)/).map(v => v.trim().replace(/\"/g, ''));\n    const obj = {};\n    headers.forEach((h, i) => obj[h] = values[i] || '');\n    return obj;\n  });\n}\n\nfunction renderTheaterDetails() {\n  const container = document.getElementById('theater-details');\n  const details = [\n    { icon: '🏢', text: theaterData.theatreName || 'Regal Theatre' },\n    { icon: '🗺️', text: theaterData.address || '' },\n    { icon: '🚗', text: theaterData.distance || 'Nearby' },\n    { icon: '📞', text: theaterData.phone || '' }\n  ];\n  container.innerHTML = details.map(d => `<div class=\"detail-item\"><span class=\"detail-icon\">${d.icon}</span>${d.text}</div>`).join('');\n}\n\nfunction renderMovies() {\n  const container = document.getElementById('movies-grid');\n  if (moviesData.length === 0) {\n    container.innerHTML = '<p style=\"grid-column: 1/-1; text-align: center;\">No movies scheduled.</p>';\n    return;\n  }\n  container.innerHTML = moviesData.map(movie => `\n    <div class=\"movie-card ${movie.genre || 'action'}\">\n      <div class=\"movie-title\">${movie.title || 'Unknown Movie'}</div>\n      <div class=\"movie-meta\">\n        <span class=\"badge badge-${getRatingClass(movie.rating)}\">${movie.rating || 'NR'}</span>\n        <span class=\"badge badge-${getFeatureClass(movie.features)}\">${movie.features || 'Standard'}</span>\n      </div>\n      <div class=\"showtimes\">\n        ${(movie.showtimes || '').split(';').filter(t => t).map(t => `<button class=\"showtime-btn\">${t.trim()}</button>`).join('')}\n      </div>\n    </div>\n  `).join('');\n  document.getElementById('loading-overlay').style.display = 'none';\n}\n\nfunction getRatingClass(rating) {\n  if (!rating) return 'gp';\n  const r = rating.toLowerCase();\n  if (r.includes('r')) return 'r';\n  if (r.includes('pg')) return 'pg';\n  return 'gp';\n}\n\nfunction getFeatureClass(feature) {\n  if (!feature) return 'gp';\n  const f = feature.toLowerCase();\n  if (f.includes('imax')) return 'imax';\n  if (f.includes('rpx')) return 'rpx';\n  return 'gp';\n}\n\ndocument.addEventListener('DOMContentLoaded', () => {\n  loadTheaterData();\n  loadMoviesData();\n});\n\ndocument.querySelectorAll('.showtime-btn').forEach(btn => {\n  btn.addEventListener('click', function() {\n    const time = this.textContent;\n    const movieTitle = this.closest('.movie-card').querySelector('.movie-title').textContent;\n    alert(`💺 Booking prompt:\\n\\nMovie: ${movieTitle}\\nShowtime: ${time}\\n\\nRedirecting to regmovies.com...`);\n  });\n});\n\nwindow.addEventListener('load', () => {\n  window.parent.postMessage({type:'resize',height:document.body.scrollHeight},'*');\n});\n</script>\n</body></html>",
